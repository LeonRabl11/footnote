# ---------------------------------------------------------------------------
# Footnote – Umgebungsvariablen
# Diese Datei IST Vorlage und wird committet. Echte Werte gehören in .env
# (gitignored) und NIEMALS ins Repo.
# Kopieren: cp .env.example .env  (Windows: Copy-Item .env.example .env)
# ---------------------------------------------------------------------------

# Neon Postgres Connection String (pgvector-fähig).
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/footnote?sslmode=require"

# Google Gemini API Key (für Embeddings und Antwort-Generierung).
GEMINI_API_KEY="your-gemini-api-key"
