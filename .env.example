# ---------------------------------------------------------------------------
# Footnote – Umgebungsvariablen
# Diese Datei IST Vorlage und wird committet. Echte Werte gehören in .env
# (gitignored) und NIEMALS ins Repo.
# Kopieren: cp .env.example .env  (Windows: Copy-Item .env.example .env)
# ---------------------------------------------------------------------------

# Neon Postgres Connection String (pgvector-fähig).
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/footnote?sslmode=require"

# Google Gemini API Key (für Embeddings und Antwort-Generierung).
GEMINI_API_KEY="your-gemini-api-key"

# ---------------------------------------------------------------------------
# Langfuse (Observability / Tracing) – OPTIONAL.
# Sind diese Werte nicht gesetzt, läuft die App normal weiter, es werden nur
# keine Traces exportiert. Keys im Langfuse-Projekt unter Settings anlegen.
# Host: EU = https://cloud.langfuse.com, US = https://us.cloud.langfuse.com.
# Kanonischer Variablenname ist LANGFUSE_BASE_URL (LANGFUSE_BASEURL = Legacy).
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"
